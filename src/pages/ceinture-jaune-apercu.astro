---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import CurriculumList from '../components/CurriculumList';

const modules = [
  {
    title: "INTRODUCTION",
    stats: "8 vidéos • 45 min",
    lessons: [
      { name: "Bienvenue dans la formation", duration: "5:30" },
      { name: "La philosophie du Karate Shotokan", duration: "8:45" },
      { name: "Le matériel nécessaire", duration: "3:45" },
      { name: "Salut et Étiquette au Dojo", duration: "10:30" },
      { name: "Échauffement spécifique débutant", duration: "8:15" },
      { name: "Le Salut (Rei)", duration: "5:00" },
      { name: "Les Termes Japonais de base", duration: "6:40" },
      { name: "Conclusion de l'introduction", duration: "5:20" }
    ]
  },
  {
    title: "LES BASES",
    stats: "9 vidéos • 1h10",
    lessons: [
      { name: "Les positions fondamentales (Zenkutsu, Kokutsu)", duration: "12:30" },
      { name: "Direct au poing (Oi-zuki)", duration: "10:15" },
      { name: "Contre-attaque (Gyaku-zuki)", duration: "8:40" },
      { name: "Coup de poing circulaire (Mawashi-zuki)", duration: "10:20" },
      { name: "Coup de poing remontant (Ura-zuki)", duration: "8:10" },
      { name: "Les coups de pieds de base (Maé-Géri)", duration: "12:40" },
      { name: "Coup de pied circulaire (Mawashi Geri)", duration: "10:30" },
      { name: "Coup de pied latéral (Yoko Geri)", duration: "10:15" },
      { name: "Coup de genou (Hiza Geri)", duration: "8:40" }
    ]
  },
  {
    title: "LES BLOCAGES - KIHON",
    stats: "5 vidéos • 45 min",
    lessons: [
      { name: "Blocage bas (Gedan Barai)", duration: "12:15" },
      { name: "Blocage haut (Age Uke)", duration: "10:30" },
      { name: "Blocage intérieur (Uchi Uke)", duration: "8:40" },
      { name: "Blocage extérieur (Soto Uke)", duration: "10:20" },
      { name: "Conclusion du module Kihon", duration: "5:40" }
    ]
  },
  {
    title: "LES KATAS",
    stats: "10 vidéos • 1h30",
    lessons: [
      { name: "Heian Shodan (Pas à pas)", duration: "12:30" },
      { name: "Heian Nidan", duration: "10:15" },
      { name: "Heian Sandan", duration: "8:40" },
      { name: "Heian Yodan", duration: "10:20" },
      { name: "Heian Godan", duration: "8:10" },
      { name: "Tekki Shodan", duration: "12:40" },
      { name: "Bassai Dai", duration: "10:30" },
      { name: "Kanku Dai", duration: "10:15" },
      { name: "Jion", duration: "8:40" },
      { name: "Enpi", duration: "5:40" }
    ]
  },
  {
    title: "KUMITE (COMBAT)",
    stats: "2 vidéos • 15 min",
    lessons: [
      { name: "Kihon Ippon Kumite (Initiation)", duration: "8:15" },
      { name: "Jiyu Ippon Kumite (Distance et Timing)", duration: "5:20" }
    ]
  },
  {
    title: "AUTRES",
    stats: "5 vidéos • 35 min",
    lessons: [
      { name: "Préparation Physique Générale", duration: "12:30" },
      { name: "Étirements et Souplesse", duration: "10:15" },
      { name: "Travail au sac de frappe", duration: "8:40" },
      { name: "Respiration et Énergie (Ibuki)", duration: "10:20" },
      { name: "Méditation (Mokuso)", duration: "8:10" }
    ]
  },
  {
    title: "BONUS",
    stats: "3 vidéos • 20 min",
    lessons: [
      { name: "Interview d'un Expert (6ème Dan)", duration: "12:40" },
      { name: "Stage spécial : Les secrets du Kime", duration: "10:30" },
      { name: "Archives Maître Taiji Kase", duration: "10:15" }
    ]
  },
  {
    title: "COACHING",
    stats: "1 vidéo • 10 min",
    lessons: [
      { name: "Session Questions / Réponses", duration: "10:20" }
    ]
  },
  {
    title: "CONCLUSION",
    stats: "1 vidéo • 2 min",
    lessons: [
      { name: "Le mot de la fin et prochaines étapes", duration: "2:40" }
    ]
  }
];

const offerUrl = "https://ecole.fudoshin.solutions/offers/eddbdb91-3af5-4345-992e-2907abb41009";
---

<Layout 
  title="Aperçu du Programme — Ceinture Jaune"
  description="Découvrez le contenu détaillé de la formation ceinture jaune : vidéos, modules techniques et exercices pratiques."
>
	<Navbar client:load />
	
  <main class="pt-32 pb-24 bg-[#FAFAFA]">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        
        {/* Banner */}
        <div class="relative h-64 md:h-80 rounded-[3rem] overflow-hidden mb-12 shadow-2xl">
          <img 
            src="https://images.unsplash.com/photo-1552072805-2a9039d00e57?auto=format&fit=crop&q=80&w=2000" 
            alt="Formation Ceinture Jaune" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-martial-black/90 to-transparent flex flex-col justify-end p-10 md:p-16">
            <h1 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tighter">Aperçu du Programme</h1>
            <p class="text-white/60 font-bold uppercase tracking-widest text-xs mt-2">Karaté Shotokan — Ceinture Jaune</p>
          </div>
        </div>

        {/* Curriculum List (Interactive) */}
        <CurriculumList client:load modules={modules} />

        {/* Sticky CTA */}
        <div class="mt-16 sticky bottom-8 z-50">
          <div class="bg-martial-black text-white p-6 md:p-8 rounded-[2.5rem] shadow-2xl flex flex-col lg:flex-row items-center justify-between gap-8 border border-white/10 backdrop-blur-md bg-opacity-95">
            <div class="text-center lg:text-left">
              <h3 class="text-lg md:text-xl font-bold uppercase tracking-tight max-w-[300px]">L'intégralité du programme pour seulement</h3>
            </div>
            
            <div class="flex flex-col md:flex-row items-center gap-6 w-full lg:w-auto">
              {/* Informational Pricing Display */}
              <div class="flex flex-col gap-3 w-full md:w-72">
                <div class="grid grid-cols-2 gap-3">
                  <div class="bg-white/10 border border-white/10 p-3 rounded-xl text-center">
                    <p class="text-xl font-black text-white leading-none">4,90€</p>
                    <p class="text-[9px] text-gray-400 uppercase font-bold mt-1">/ mois</p>
                  </div>
                  <div class="bg-white/5 border border-white/5 p-3 rounded-xl text-center opacity-60">
                    <p class="text-xl font-black text-white leading-none">49€</p>
                    <p class="text-[9px] text-gray-400 uppercase font-bold mt-1">/ an</p>
                  </div>
                </div>
                <p class="text-[10px] text-martial-red font-black uppercase tracking-widest text-center animate-pulse">
                  1 semaine d'essai gratuit
                </p>
              </div>

              {/* Single Action Button */}
              <a 
                href={offerUrl} 
                target="_blank" 
                rel="noopener noreferrer"
                class="btn-primary !bg-martial-red !text-white !px-10 !py-4 w-full md:w-auto text-center shadow-2xl shadow-martial-red/40 hover:scale-105 transition-transform text-sm font-black uppercase tracking-widest whitespace-nowrap"
              >
                Commencez l'essai
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

	<Footer client:visible />
</Layout>
