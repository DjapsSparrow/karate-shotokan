---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import CurriculumList from '../components/CurriculumList';
import StickyCTA from '../components/StickyCTA';
import BackToCourses from '../components/BackToCourses';

const modules = [
  {
    title: "Introduction",
    stats: "8 leçons",
    lessons: [
      { name: "Présentation de la formation", duration: "5:30" },
      { name: "Un peu d'histoire", duration: "8:45" },
      { name: "La tenue", duration: "3:45" },
      { name: "Le cérémonial", duration: "10:30" },
      { name: "L'échauffement", duration: "8:15" },
      { name: "L'entrainement", duration: "12:00" },
      { name: "Les niveaux", duration: "6:40" },
      { name: "Le déroulé de l'examen", duration: "15:20" }
    ]
  },
  {
    title: "Les positions",
    stats: "9 leçons",
    lessons: [
      { name: "Introduction", duration: "2:30" },
      { name: "HEÏSOKU DACHI", duration: "4:15" },
      { name: "MUSUBI DACHI", duration: "4:40" },
      { name: "HEIKO DACHI", duration: "4:20" },
      { name: "UCHI HACHIJI DACHI", duration: "4:10" },
      { name: "HACHIJI DACHI", duration: "4:40" },
      { name: "ZEN KUTSU DACHI", duration: "8:30" },
      { name: "KO KUTSU DACHI", duration: "8:15" },
      { name: "REINOJI DACHI", duration: "6:40" }
    ]
  },
  {
    title: "Les déplacements",
    stats: "5 leçons",
    lessons: [
      { name: "Introduction", duration: "3:15" },
      { name: "AYUMI ASHI", duration: "8:30" },
      { name: "HIKI ASHI", duration: "6:40" },
      { name: "MAWARI ASHI", duration: "7:20" },
      { name: "USHIRO MAWARI ASHI", duration: "9:40" }
    ]
  },
  {
    title: "Les techniques",
    stats: "10 leçons",
    lessons: [
      { name: "Introduction", duration: "4:30" },
      { name: "CHOKU TSUKI", duration: "10:15" },
      { name: "OÏ ZUKI", duration: "12:40" },
      { name: "TETSUI", duration: "8:20" },
      { name: "JODAN SHUTO AGÉ UKÉ", duration: "10:10" },
      { name: "GEDAN BARAÏ", duration: "12:40" },
      { name: "JODAN AGÉ UKÉ", duration: "10:30" },
      { name: "SHUTO UDÉ UKÉ SHUDAN", duration: "10:15" },
      { name: "MAÉ GÉRI", duration: "12:40" },
      { name: "MAWASHI GÉRI", duration: "15:20" }
    ]
  },
  {
    title: "Le kihon",
    stats: "2 leçons",
    lessons: [
      { name: "Introduction", duration: "3:15" },
      { name: "KIHON", duration: "25:20" }
    ]
  },
  {
    title: "Le kata",
    stats: "5 leçons",
    lessons: [
      { name: "Introduction", duration: "5:30" },
      { name: "HEÏAN SHODAN", duration: "12:45" },
      { name: "Décomposition du kata", duration: "25:30" },
      { name: "EMBUSEN", duration: "8:45" },
      { name: "BUNKAÏ", duration: "15:15" }
    ]
  },
  {
    title: "Le Kumite",
    stats: "3 leçons",
    lessons: [
      { name: "Introduction", duration: "4:15" },
      { name: "KIHON IPPON KUMITÉ", duration: "12:20" },
      { name: "SANBON/GOHON KUMITE", duration: "15:40" }
    ]
  },
  {
    title: "Conclusion",
    stats: "1 leçon",
    lessons: [
      { name: "Synthèse", duration: "10:20" }
    ]
  }
];

const offerUrl = "https://ecole.fudoshin.solutions/offers/eddbdb91-3af5-4345-992e-2907abb41009";
---

<Layout 
  title="Aperçu du Programme — Ceinture Jaune"
  description="Découvrez le contenu détaillé de la formation ceinture jaune : vidéos, modules techniques et exercices pratiques."
>
	<Navbar client:load beltColor="yellow-400" />
	
  <main class="pt-32 pb-24 bg-[#FAFAFA]">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        
        {/* Banner */}
        <div class="relative h-64 md:h-80 rounded-[3rem] overflow-hidden mb-12 shadow-2xl">
          <img 
            src="/images/hero-apercu.jpg" 
            alt="Formation Ceinture Jaune" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-martial-black/90 to-transparent flex flex-col justify-end p-10 md:p-16">
            <h1 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tighter">Aperçu du Programme</h1>
            <p class="text-white/60 font-bold uppercase tracking-widest text-xs mt-2">Karaté Shotokan — Ceinture Jaune</p>
          </div>
        </div>

        {/* Curriculum List (Interactive) */}
        <CurriculumList client:load modules={modules} color="yellow-400" />

        {/* Dynamic Sticky CTA */}
        <StickyCTA client:load offerUrl={offerUrl} color="yellow-400" />

      </div>
    </div>
  </main>
  <BackToCourses client:visible />
	<Footer client:visible />
</Layout>
