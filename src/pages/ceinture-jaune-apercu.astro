---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';

const modules = [
  {
    title: "INTRODUCTION",
    stats: "8 vidéos • 45 min",
    lessons: [
      { name: "Bienvenue dans la formation", duration: "5:30" },
      { name: "La philosophie du Karate Shotokan", duration: "8:45" },
      { name: "Le matériel nécessaire", duration: "3:45" },
      { name: "Salut et Étiquette au Dojo", duration: "10:30" },
      { name: "Échauffement spécifique débutant", duration: "8:15" },
      { name: "Le Salut (Rei)", duration: "5:00" },
      { name: "Les Termes Japonais de base", duration: "6:40" },
      { name: "Conclusion de l'introduction", duration: "5:20" }
    ]
  },
  {
    title: "LES BASES",
    stats: "9 vidéos • 1h10",
    lessons: [
      { name: "Les positions fondamentales (Zenkutsu, Kokutsu)", duration: "12:30" },
      { name: "Direct au poing (Oi-zuki)", duration: "10:15" },
      { name: "Contre-attaque (Gyaku-zuki)", duration: "8:40" },
      { name: "Coup de poing circulaire (Mawashi-zuki)", duration: "10:20" },
      { name: "Coup de poing remontant (Ura-zuki)", duration: "8:10" },
      { name: "Les coups de pieds de base (Maé-Géri)", duration: "12:40" },
      { name: "Coup de pied circulaire (Mawashi Geri)", duration: "10:30" },
      { name: "Coup de pied latéral (Yoko Geri)", duration: "10:15" },
      { name: "Coup de genou (Hiza Geri)", duration: "8:40" }
    ]
  },
  {
    title: "LES BLOCAGES - KIHON",
    stats: "5 vidéos • 45 min",
    lessons: [
      { name: "Blocage bas (Gedan Barai)", duration: "12:15" },
      { name: "Blocage haut (Age Uke)", duration: "10:30" },
      { name: "Blocage intérieur (Uchi Uke)", duration: "8:40" },
      { name: "Blocage extérieur (Soto Uke)", duration: "10:20" },
      { name: "Conclusion du module Kihon", duration: "5:40" }
    ]
  },
  {
    title: "LES KATAS",
    stats: "10 vidéos • 1h30",
    lessons: [
      { name: "Heian Shodan (Pas à pas)", duration: "12:30" },
      { name: "Heian Nidan", duration: "10:15" },
      { name: "Heian Sandan", duration: "8:40" },
      { name: "Heian Yodan", duration: "10:20" },
      { name: "Heian Godan", duration: "8:10" },
      { name: "Tekki Shodan", duration: "12:40" },
      { name: "Bassai Dai", duration: "10:30" },
      { name: "Kanku Dai", duration: "10:15" },
      { name: "Jion", duration: "8:40" },
      { name: "Enpi", duration: "5:40" }
    ]
  },
  {
    title: "KUMITE (COMBAT)",
    stats: "2 vidéos • 15 min",
    lessons: [
      { name: "Kihon Ippon Kumite (Initiation)", duration: "8:15" },
      { name: "Jiyu Ippon Kumite (Distance et Timing)", duration: "5:20" }
    ]
  },
  {
    title: "AUTRES",
    stats: "5 vidéos • 35 min",
    lessons: [
      { name: "Préparation Physique Générale", duration: "12:30" },
      { name: "Étirements et Souplesse", duration: "10:15" },
      { name: "Travail au sac de frappe", duration: "8:40" },
      { name: "Respiration et Énergie (Ibuki)", duration: "10:20" },
      { name: "Méditation (Mokuso)", duration: "8:10" }
    ]
  },
  {
    title: "BONUS",
    stats: "3 vidéos • 20 min",
    lessons: [
      { name: "Interview d'un Expert (6ème Dan)", duration: "12:40" },
      { name: "Stage spécial : Les secrets du Kime", duration: "10:30" },
      { name: "Archives Maître Taiji Kase", duration: "10:15" }
    ]
  },
  {
    title: "COACHING",
    stats: "1 vidéo • 10 min",
    lessons: [
      { name: "Session Questions / Réponses", duration: "10:20" }
    ]
  },
  {
    title: "CONCLUSION",
    stats: "1 vidéo • 2 min",
    lessons: [
      { name: "Le mot de la fin et prochaines étapes", duration: "2:40" }
    ]
  }
];

const offerUrl = "https://ecole.fudoshin.solutions/offers/eddbdb91-3af5-4345-992e-2907abb41009";
---

<Layout 
  title="Aperçu du Programme — Ceinture Jaune"
  description="Découvrez le contenu détaillé de la formation ceinture jaune : vidéos, modules techniques et exercices pratiques."
>
	<Navbar client:load />
	
  <main class="pt-32 pb-24 bg-[#FAFAFA]">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        
        {/* Banner */}
        <div class="relative h-64 md:h-80 rounded-[3rem] overflow-hidden mb-12 shadow-2xl">
          <img 
            src="https://images.unsplash.com/photo-1552072805-2a9039d00e57?auto=format&fit=crop&q=80&w=2000" 
            alt="Formation Ceinture Jaune" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-martial-black/90 to-transparent flex flex-col justify-end p-10 md:p-16">
            <h1 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tighter">Aperçu du Programme</h1>
            <p class="text-white/60 font-bold uppercase tracking-widest text-xs mt-2">Karaté Shotokan — Ceinture Jaune</p>
          </div>
        </div>

        {/* Curriculum List */}
        <div class="space-y-6">
          {modules.map((module) => (
            <div class="bg-white border border-gray-100 rounded-[2rem] overflow-hidden shadow-sm">
              <div class="px-8 py-6 bg-martial-gray border-b border-gray-100 flex items-center justify-between">
                <div>
                  <h2 class="font-black text-lg uppercase tracking-tight text-martial-black">{module.title}</h2>
                  <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mt-1">{module.stats}</p>
                </div>
                <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center border border-gray-200">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
              </div>
              <div class="p-4">
                <ul class="space-y-1">
                  {module.lessons.map((lesson) => (
                    <li class="flex items-center justify-between p-4 rounded-xl hover:bg-martial-gray transition-colors group">
                      <div class="flex items-center gap-4">
                        <div class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center text-gray-400 group-hover:bg-martial-red group-hover:text-white transition-colors">
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg>
                        </div>
                        <span class="text-sm font-medium text-gray-700 group-hover:text-martial-black transition-colors">{lesson.name}</span>
                      </div>
                      <span class="text-xs font-bold text-gray-400 font-mono">{lesson.duration}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>

        {/* Sticky CTA */}
        <div class="mt-16 sticky bottom-8 z-50">
          <div class="bg-martial-black text-white p-6 md:p-8 rounded-[2.5rem] shadow-2xl flex flex-col md:flex-row items-center justify-between gap-8 border border-white/10 backdrop-blur-md bg-opacity-95">
            <div class="hidden md:block">
              <p class="text-martial-red font-black uppercase text-[10px] tracking-[0.3em] mb-1">Prêt à commencer ?</p>
              <h3 class="text-xl font-bold uppercase tracking-tight">Accédez à l'intégralité du programme</h3>
            </div>
            
            <div class="flex flex-col gap-3 w-full md:w-auto">
              {/* Monthly Option */}
              <a 
                href={offerUrl} 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-center justify-between gap-6 bg-white/10 hover:bg-white/20 border border-white/10 p-4 rounded-2xl transition-all group"
              >
                <div class="text-left">
                  <p class="font-bold text-sm">S'abonner pour 4,90 €</p>
                  <p class="text-[10px] text-gray-400">chaque mois (1 semaine d'essai gratuit)</p>
                </div>
                <div class="w-6 h-6 rounded-full border-2 border-martial-red flex items-center justify-center">
                  <div class="w-3 h-3 bg-martial-red rounded-full"></div>
                </div>
              </a>

              {/* Yearly Option */}
              <a 
                href={offerUrl} 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-center justify-between gap-6 bg-white/5 hover:bg-white/15 border border-white/5 p-4 rounded-2xl transition-all group"
              >
                <div class="text-left">
                  <p class="font-bold text-sm text-gray-300">S'abonner pour 49 €</p>
                  <p class="text-[10px] text-gray-500">chaque année (1 semaine d'essai gratuit)</p>
                </div>
                <div class="w-6 h-6 rounded-full border-2 border-gray-700"></div>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

	<Footer client:visible />
</Layout>
