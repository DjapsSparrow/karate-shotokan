---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import BeltPageTemplate from '../components/BeltPageTemplate';
import Footer from '../components/Footer';

const curriculum = [
  "Module 1 : Maîtrise Technique & Kata (Heian Godan, Tekki Shodan, Bassai Dai, Kanku Dai).",
  "Module 2 : L'art du combat (Kihon Ippon Kumite, Jiyu Ippon Kumite, Jiyu Kumite).",
  "Module 3 : Kihon Supérieur (techniques avancées, fluidité, enracinement).",
  "Module 4 : Préparation Mentale (gestion du stress, attitude martiale, respiration).",
  "Module 5 : Histoire et Philosophie (Lignage Kase, Code moral du Bushido)."
];
---

<Layout 
  title="Formation Ceinture Noire Karaté Shotokan — L'Accomplissement"
  description="L'accomplissement d'un parcours, le début d'un chemin. Préparez votre passage de grade 1er Dan avec rigueur, précision et sérénité."
>
	<Navbar client:load />
	<main>
		<BeltPageTemplate 
      client:load
      color="Noire"
      hex="#050505"
      title="L'accomplissement"
      description="Cette formation d'élite vous donne toutes les clés pour réussir l'examen du 1er Dan FFK. Rejoignez le cercle des ceintures noires avec brio."
      curriculum={curriculum}
      ctaLink="https://ecole.fudoshin.solutions/offers/eba985cc-b2e0-4dab-afb2-5b73cde8cbc2"
    />
	</main>
	<Footer client:visible />
</Layout>
