---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ShineBorder from '../components/ShineBorder';

const offerUrl = "https://fudoshin.schoolmaker.co/offers/dc2cb6fa-53f5-45f0-a811-9d023db2ddfe";

const dan2Katas = [
  { name: "Introduction", duration: "2 min" },
  { name: "Bassai Dai : Le kata", duration: "10 min" },
  { name: "Bassai Dai : Décomposition du Kata", duration: "15 min" },
  { name: "Empi : Le kata", duration: "10 min" },
  { name: "Empi : Décomposition du kata", duration: "18 min" },
  { name: "Jion : Le kata", duration: "10 min" },
  { name: "Jion : Décomposition du Kata", duration: "16 min" },
  { name: "Hangetsu : Le kata", duration: "11 min" },
  { name: "Hangetsu : Décomposition du kata", duration: "17 min" },
  { name: "Kanku Dai : Le kata", duration: "12 min" },
  { name: "Kanku Dai : Décomposition du kata", duration: "20 min" },
];

const dan3Katas = [
  { name: "Nijushiho", duration: "10 min" },
  { name: "Gankaku : Décomposition du Kata", duration: "18 min" },
  { name: "Jitte : Décomposition du kata", duration: "15 min" },
];
---

<Layout 
  title="Aperçu — Formation Katas Supérieurs Karaté Shotokan"
  description="Consultez le programme détaillé des katas supérieurs du 2e et 3e Dan. Apprenez le Shotokan traditionnel."
>
	<Navbar client:load />
	
  <main class="pt-32 pb-24 bg-martial-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        
        {/* Banner */}
        <div class="rounded-[2.5rem] overflow-hidden shadow-2xl mb-12 border border-white">
          <img src="/assets/katas/banner.png" alt="Karaté Shotokan Banner" class="w-full h-auto" />
        </div>

        {/* Title Section */}
        <div class="text-center mb-16">
          <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter mb-4 dark:text-white">
            Karaté Shotokan - <span class="text-martial-red">Les katas supérieurs</span>
          </h1>
          <p class="text-gray-500 dark:text-gray-400 font-medium">Dans cette formation, nous allons vous enseigner tous les katas supérieurs.</p>
        </div>

        {/* Floating CTA */}
        <div class="sticky top-28 z-40 mb-12 flex flex-col items-center gap-4">
          <a href={offerUrl} target="_blank" rel="noopener noreferrer" class="bg-martial-red text-white px-8 py-4 rounded-full font-black uppercase tracking-widest shadow-xl shadow-martial-red/20 hover:scale-105 transition-transform flex items-center gap-3">
            S'abonner maintenant
            <span class="bg-white/20 px-3 py-1 rounded-full text-[10px]">9,90€/mois</span>
          </a>
          <p class="text-martial-red font-bold text-xs uppercase tracking-widest animate-pulse">
            1 semaine d'essai gratuite
          </p>
        </div>

        {/* Section: Introduction */}
        <section class="relative bg-white dark:bg-black/20 rounded-[2rem] p-8 md:p-12 shadow-sm mb-12">
          <ShineBorder client:load borderWidth={1} duration={14} shineColor="#E31B23" />
          <div class="flex items-center gap-4 mb-8">
            <div class="w-1.5 h-8 bg-martial-red rounded-full"></div>
            <h2 class="text-2xl font-black uppercase tracking-tight dark:text-white">Introduction</h2>
          </div>
          <div class="rounded-2xl overflow-hidden mb-8">
            <img src="/assets/katas/intro.png" alt="Introduction" class="w-full h-auto" />
          </div>
          <p class="text-gray-600 dark:text-gray-400 mb-6 font-medium">Dans cette formation, nous allons vous enseigner tous les katas supérieurs.</p>
          <div class="flex items-center gap-6 text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest border-t border-gray-50 dark:border-white/10 pt-6">
            <span class="flex items-center gap-2"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg> 1 Vidéo</span>
            <span class="flex items-center gap-2"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg> 5 min</span>
          </div>
        </section>

        {/* Section: 2e Dan */}
        <section class="relative bg-white dark:bg-black/20 rounded-[2rem] p-8 md:p-12 shadow-sm mb-12">
          <ShineBorder client:load borderWidth={1} duration={14} shineColor="#E31B23" />
          <div class="flex items-center gap-4 mb-8">
            <div class="w-1.5 h-8 bg-martial-red rounded-full"></div>
            <h2 class="text-2xl font-black uppercase tracking-tight dark:text-white">Les katas du 2e dan</h2>
          </div>
          <div class="rounded-2xl overflow-hidden mb-8">
            <img src="/assets/katas/group.png" alt="2e Dan Katas" class="w-full h-auto" />
          </div>
          <p class="text-gray-600 dark:text-gray-400 mb-8 font-medium">Nous allons passer en revue les différents katas qui vous permettront d'obtenir votre 2e dan.</p>
          
          <div class="space-y-3">
            {dan2Katas.map((kata, i) => (
              <div key={i} class="flex items-center justify-between p-4 rounded-xl border border-gray-50 dark:border-white/5 hover:border-martial-red/20 hover:bg-martial-gray dark:hover:bg-white/5 transition-all group">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 bg-gray-100 dark:bg-zinc-800 rounded-full flex items-center justify-center text-gray-400 dark:text-gray-500 group-hover:bg-martial-red/10 group-hover:text-martial-red transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  </div>
                  <span class="font-bold text-gray-700 dark:text-gray-300 uppercase tracking-tight text-sm group-hover:text-martial-black dark:group-hover:text-white transition-colors">{kata.name}</span>
                </div>
                <span class="text-[10px] font-black text-gray-300 dark:text-gray-600 uppercase tracking-widest">{kata.duration}</span>
              </div>
            ))}
          </div>
        </section>

        {/* Section: 3e Dan */}
        <section class="relative bg-white dark:bg-black/20 rounded-[2rem] p-8 md:p-12 shadow-sm mb-12">
          <ShineBorder client:load borderWidth={1} duration={14} shineColor="#E31B23" />
          <div class="flex items-center gap-4 mb-8">
            <div class="w-1.5 h-8 bg-martial-red rounded-full"></div>
            <h2 class="text-2xl font-black uppercase tracking-tight dark:text-white">Les katas du 3e dan</h2>
          </div>
          <div class="rounded-2xl overflow-hidden mb-8">
            <img src="/assets/katas/group.png" alt="3e Dan Katas" class="w-full h-auto" />
          </div>
          <p class="text-gray-600 dark:text-gray-400 mb-8 font-medium">Nous allons passer en revue les différents katas qui vous permettront d'obtenir votre 3e dan.</p>
          
          <div class="space-y-3">
            {dan3Katas.map((kata, i) => (
              <div key={i} class="flex items-center justify-between p-4 rounded-xl border border-gray-50 dark:border-white/5 hover:border-martial-red/20 hover:bg-martial-gray dark:hover:bg-white/5 transition-all group">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 bg-gray-100 dark:bg-zinc-800 rounded-full flex items-center justify-center text-gray-400 dark:text-gray-500 group-hover:bg-martial-red/10 group-hover:text-martial-red transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  </div>
                  <span class="font-bold text-gray-700 dark:text-gray-300 uppercase tracking-tight text-sm group-hover:text-martial-black dark:group-hover:text-white transition-colors">{kata.name}</span>
                </div>
                <span class="text-[10px] font-black text-gray-300 dark:text-gray-600 uppercase tracking-widest">{kata.duration}</span>
              </div>
            ))}
          </div>
        </section>

        {/* Section: Conclusion */}
        <section class="relative bg-white dark:bg-black/20 rounded-[2rem] p-8 md:p-12 shadow-sm mb-20">
          <ShineBorder client:load borderWidth={2} duration={8} shineColor={["#E31B23", "#FFFFFF"]} />
          <div class="flex items-center gap-4 mb-8">
            <div class="w-1.5 h-8 bg-martial-red rounded-full"></div>
            <h2 class="text-2xl font-black uppercase tracking-tight dark:text-white">Conclusion</h2>
          </div>
          <div class="rounded-2xl overflow-hidden mb-8">
            <img src="/assets/katas/conclusion.png" alt="Conclusion" class="w-full h-auto" />
          </div>
          <div class="flex items-center justify-between p-4 rounded-xl border border-martial-red/20 bg-martial-gray dark:bg-white/5 mb-8">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-martial-red text-white rounded-full flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <span class="font-bold text-martial-black dark:text-white uppercase tracking-tight text-sm">Synthèse</span>
            </div>
            <span class="text-[10px] font-black text-martial-red uppercase tracking-widest">10 min</span>
          </div>

          <div class="text-center space-y-4">
            <a href={offerUrl} target="_blank" rel="noopener noreferrer" class="btn-primary w-full md:w-auto inline-block !px-12 !py-5">
              Accéder au programme complet
            </a>
            <p class="text-martial-red font-bold text-sm uppercase tracking-widest">
              1 semaine d'essai gratuite
            </p>
          </div>
        </section>

      </div>
    </div>
  </main>

	<Footer client:visible />
</Layout>
