---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import CurriculumList from '../components/CurriculumList';
import StickyCTA from '../components/StickyCTA';
import BackToCourses from '../components/BackToCourses';

const modules = [
  {
    title: "Introduction",
    stats: "2 leçons",
    lessons: [
      { name: "Introduction", duration: "5:30" },
      { name: "Le déroulé de l'examen", duration: "10:15" }
    ]
  },
  {
    title: "Les positions",
    stats: "2 leçons",
    lessons: [
      { name: "Introduction", duration: "3:45" },
      { name: "KIBA DACHI", duration: "8:30" },
      { name: "KOSA DACHI", duration: "6:40" }
    ]
  },
  {
    title: "Les déplacements",
    stats: "1 leçon",
    lessons: [
      { name: "Introduction", duration: "3:15" },
      { name: "OKURI ASHI", duration: "9:20" }
    ]
  },
  {
    title: "Les techniques",
    stats: "6 leçons",
    lessons: [
      { name: "FUMI KOMI", duration: "8:15" },
      { name: "ENPI UKÉ", duration: "7:40" },
      { name: "TATÉ SHUTO", duration: "6:20" },
      { name: "MAWASHI TSUKI", duration: "9:10" },
      { name: "USHIRO ENPI", duration: "8:20" },
      { name: "URA MAWASHI GERI", duration: "12:40" }
    ]
  },
  {
    title: "Le kihon",
    stats: "2 leçons",
    lessons: [
      { name: "Introduction", duration: "3:15" },
      { name: "KIHON linéaire", duration: "15:20" },
      { name: "KIHON sur cibles", duration: "18:45" }
    ]
  },
  {
    title: "Le kata",
    stats: "4 leçons",
    lessons: [
      { name: "Introduction", duration: "5:30" },
      { name: "HEÏAN SANDAN", duration: "15:45" },
      { name: "Décomposition du kata", duration: "28:30" },
      { name: "BUNKAÏ", duration: "18:15" }
    ]
  },
  {
    title: "Le Kumite",
    stats: "3 leçons",
    lessons: [
      { name: "Introduction", duration: "4:15" },
      { name: "JIYU IPPON KUMITÉ", duration: "15:20" },
      { name: "JIYU KUMITÉ", duration: "20:40" }
    ]
  },
  {
    title: "Conclusion",
    stats: "1 leçon",
    lessons: [
      { name: "Synthèse", duration: "10:20" }
    ]
  }
];

const offerUrl = "https://ecole.fudoshin.solutions/offers/20697fe9-e447-4082-b338-605e0a9ddadd";
---

<Layout 
  title="Aperçu du Programme — Ceinture Verte"
  description="Découvrez le contenu détaillé de la formation ceinture verte : Kiba Dachi, Heian Sandan et Kumité libre."
>
	<Navbar client:load beltColor="emerald-600" />
	
  <main class="pt-32 pb-24 bg-[#FAFAFA]">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        
        {/* Banner */}
        <div class="relative h-64 md:h-80 rounded-[3rem] overflow-hidden mb-12 shadow-2xl">
          <img 
            src="https://images.unsplash.com/photo-1555597673-b21d5c935865?auto=format&fit=crop&q=80&w=2000" 
            alt="Formation Ceinture Verte" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-martial-black/90 to-transparent flex flex-col justify-end p-10 md:p-16">
            <h1 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tighter">Aperçu du Programme</h1>
            <p class="text-white/60 font-bold uppercase tracking-widest text-xs mt-2">Karaté Shotokan — Ceinture Verte</p>
          </div>
        </div>

        <div class="mb-12">
          <h2 class="text-2xl font-black uppercase tracking-tight mb-4 text-martial-black">Karaté Shotokan - Ceinture Verte</h2>
          <p class="text-gray-600 font-medium">Cette formation a pour but de vous préparer à votre passage de grade menant vers la ceinture Verte.</p>
        </div>

        {/* Curriculum List (Interactive) */}
        <CurriculumList client:load modules={modules} color="emerald-600" />

        {/* Dynamic Sticky CTA */}
        <StickyCTA 
          client:load 
          offerUrl={offerUrl} 
          color="emerald-600"
          priceMonthly="8,90€" 
          priceYearly="89€" 
        />

      </div>
    </div>
  </main>
  <BackToCourses client:visible />
	<Footer client:visible />
</Layout>
