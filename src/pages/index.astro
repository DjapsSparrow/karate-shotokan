---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import NoveltySection from '../components/NoveltySection';
import CourseStructure from '../components/CourseStructure';
import VideoTrailer from '../components/VideoTrailer';
import PricingGrid from '../components/PricingGrid';
import AuthoritySection from '../components/AuthoritySection';
import Testimonials from '../components/Testimonials';
import Footer from '../components/Footer';
import philippeImage from '../assets/images/philippe-bouvier.jpg';
import kataImage from '../assets/images/katas-superieurs.jpg';
---

<Layout>
	<Navbar client:load />
	<main>
		<Hero client:load />
		<NoveltySection client:visible imageSrc={kataImage.src} />
		<CourseStructure client:visible />
		<VideoTrailer client:visible />
		<PricingGrid client:visible />
		<AuthoritySection client:visible imageSrc={philippeImage.src} />
		<Testimonials client:visible />
	</main>
	<Footer client:visible />
</Layout>
