---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
---

<Layout 
  title="Le Dojo Virtuel — Apprendre le Karaté chez soi"
  description="Transformez votre espace en dojo. Notre plateforme vous permet de pratiquer le Karaté Shotokan n'importe où, avec une pédagogie adaptée au travail en ligne."
>
	<Navbar client:load />
	<main class="pt-32 pb-24">
    <div className="container-custom">
      <div className="max-w-4xl mx-auto">
        <h1 className="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-12 text-center">
          Le <span className="text-martial-red">Dojo</span> Virtuel
        </h1>
        
        <div className="grid grid-cols-1 md:grid-cols-2 gap-12 mt-20">
          <div className="bg-martial-gray p-10 rounded-[2.5rem] border border-gray-100">
            <h3 className="text-2xl font-black uppercase mb-6">Pratique au Quotidien</h3>
            <p className="text-gray-600 leading-relaxed">
              Le dojo n'est pas qu'un lieu physique, c'est un état d'esprit. Grâce à nos formations vidéo, vous pouvez transformer votre salon ou votre jardin en espace d'entraînement sacré.
            </p>
          </div>
          <div className="bg-martial-gray p-10 rounded-[2.5rem] border border-gray-100">
            <h3 className="text-2xl font-black uppercase mb-6">Accompagnement</h3>
            <p className="text-gray-600 leading-relaxed">
              Même à distance, vous n'êtes pas seul. Philippe Bouvier décompose chaque mouvement pour que vous puissiez corriger vos erreurs et progresser avec la même rigueur qu'en club.
            </p>
          </div>
        </div>

        <div className="mt-20 relative rounded-[3rem] overflow-hidden aspect-video">
          <img 
            src="https://images.unsplash.com/photo-1555597673-b21d5c935865?auto=format&fit=crop&q=80&w=1200" 
            alt="Dojo traditionnel" 
            className="w-full h-full object-cover grayscale opacity-80"
          />
          <div className="absolute inset-0 bg-gradient-to-t from-martial-black/80 to-transparent flex items-end p-12">
            <p className="text-white text-xl font-light italic">
              "L'esprit est le même, que vous soyez sur un tatami ou chez vous. La sincérité de l'effort est ce qui compte."
            </p>
          </div>
        </div>
      </div>
    </div>
	</main>
	<Footer client:visible />
</Layout>
