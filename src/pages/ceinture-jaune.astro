---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import BeltPageTemplate from '../components/BeltPageTemplate';
import Footer from '../components/Footer';

const curriculum = [
  "Maîtrise du Kihon : positions Zenkutsu Dachi, blocages Gedan Barai et attaques Oi Tsuki.",
  "Décryptage de Heian Shodan : décomposition mouvement par mouvement avec focus sur les pivots.",
  "Coordination et Équilibre : stabilisation du centre de gravité et coordination corps haut/bas.",
  "L'esprit du grade : conseils sur l'attitude, le Kiai et la présence pour l'examen.",
  "Apprentissage Visuel : angles de vue optimisés pour le placement précis des pieds et mains."
];
---

<Layout 
  title="Formation Ceinture Jaune Karaté Shotokan — Apprendre les bases"
  description="Franchissez la première étape décisive de votre parcours martial. Maîtrisez les bases fondamentales et votre premier kata, Heian Shodan."
>
	<Navbar client:load />
	<main>
		<BeltPageTemplate 
      client:load
      color="Jaune"
      hex="#FFD700"
      title="Franchissez la première étape"
      description="Cette formation complète vous prépare techniquement et mentalement au passage de grade de la ceinture jaune. Construisez des fondations solides et inébranlables."
      curriculum={curriculum}
      ctaLink="https://ecole.fudoshin.solutions/offers/eddbdb91-3af5-4345-992e-2907abb41009"
    />
	</main>
	<Footer client:visible />
</Layout>
